# GROUP MANAGEMENT
groups.system=wheel;libvirt;docker;wireshark
# USER MANAGEMENT
user.login=krem
user.id=1000

# DOTFILES REPO
# Description : repo of config files to be installed in ~/.config
dotfiles.repo = https://github.com/clementdlg/dotfiles.git
dotfiles.branch = hyprland

# NATIVE PACKAGES
# Description : packages to be installed with the native package manager, sorted by groups
pkg.package-managers = npm;rust;flatpak;python-pip;python-pipx

pkg.desktop-core=hyprland;sddm;rofi-wayland;waybar;hyprpaper;hyprshot;swaync;xdg-desktop-portal;xdg-desktop-portal-hyprland;hyprlock;hypridle;ttf-dejavu

pkg.desktop-apps=alacritty;thunar;vlc;syncthing;cosmic-files;cosmic-text-editor;cosmic-applets;firefox

pkg.gpu=xf86-video-intel

pkg.assets=ttf-dejavu-nerd;ttf-noto-nerd;papirus-icon-theme

pkg.device-management=nwg-displays;network-manager-applet;bluez;brightnessctl;playerctl

pkg.audio-stack=pipewire;pipewire-docs;wireplumber;pipewire-pulse;pipewire-audio;pavucontrol;alsa-utils

pkg.tty=vim;neovim;tmux;htop;btop;fzf;bat;eza;unzip;tar;diffutils;git;ripgrep;tree;tldr;tokei

# pkg.virtualisation=libvirt;qemu-desktop;virt-install;virt-viewer


pkg.networking=net-tools;iputils;inetutils;traceroute;openbsd-netcat;bind;wget;curl;wireguard-tools
# pkg.devops=openssh;docker;docker-compose;ansible 

# 3RD PARTY PACKAGES
# Description : packages installed using third-party package managers
flatpak.packages=com.discordapp.Discord;com.github.wwmm.easyeffects;md.obsidian.Obsidian

# pipx.packages=labctl;yt-dlp

# npm.packages =
# cargo.packages =
# aur.packages=

# GIT REPOSITORIES
# Description : repos to clone in $repo.path base directory
git-clone.scripts.path=/home/krem/scripts
git-clone.scripts.url=https://github.com/clementdlg/scripts
# git-clone.scripts.branch=master

git-clone.dev.path=/home/krem/arch-btrfs-install
git-clone.dev.url=https://github.com/clementdlg/arch-btrfs-install

####    SYSTEMD UNITS    ####
# Description : systemd unit file to enable
systemd.target=graphical
systemd.service.system=NetworkManager;bluetooth;libvirtd;sddm
systemd.service.user=syncthing;pipewire;pipewire-pulse;xdg-desktop-portal-hyprland

####    FIREWALL RULES    ####
# Description : manage firewall rules using firewall-cmd
# fw.services=syncthing
# fw.ports=

